# Git
.git
.gitignore
.gitattributes

# CI/CD
.github

# Build output. We exclude the Gradle work tree but allow the artifacts the
# Dockerfile actually consumes (produced by `./gradlew bootJar` or
# downloaded from CI's application-jar artifact).
build/*
!build/libs/
!build/otel-agent/
!build/pyroscope-agent/
.gradle/
target/

# Node modules (npm install runs during build)
node_modules/

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr

# OS
.DS_Store
Thumbs.db

# Development config
.claude/
.tool-versions
*.md
!README.md

# Test artifacts (not needed for production build)
src/test/e2e/
playwright-report/
test-results/
coverage/

# Docker Compose (local development only)
docker-compose.yml
docker-compose*.yml

# CI/CD configs
codecov.yml

# Code formatting (dev-only)
.prettierrc
.prettierignore

# Lint/test configs (not needed for production JAR build)
eslint.config.js
vitest.config.ts
playwright.config.ts
tsconfig.node.json
